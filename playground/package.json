    "@storybook/react-vite": "8.6.18",
    "@storybook/test-runner": "0.21.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "chromatic": "11.20.0",
    "playwright": "1.49.0",
    "postcss": "8.4.49",
    "sonner": "2.0.7",
    "storybook": "8.6.18",
