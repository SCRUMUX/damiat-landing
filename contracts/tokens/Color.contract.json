        "color_border_strong": { "aliasLight": "core_gray_25",  "aliasDark": "core_gray_65", "hexLight": "#CBD5E1", "hexDark": "#485B76" },
        "color_divider":       { "aliasLight": "core_gray_15",  "aliasDark": "core_gray_80", "hexLight": "#E5E7EB", "hexDark": "#243041" }
      }
    },
    "semanticStates": {
      "description": "Feedback and status colors: success, warning, danger, info",
      "tokens": {
