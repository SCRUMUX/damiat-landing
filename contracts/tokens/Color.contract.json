    "dataVisualization": {
      "description": "Chart and data visualization categorical palette",
      "tokens": {
        "color_viz_categorical_1": { "aliasLight": "core_blue_50",   "aliasDark": "core_blue_50",   "hexLight": "#5B9CFF", "hexDark": "#5B9CFF" },
        "color_viz_categorical_2": { "aliasLight": "core_cyan_50",   "aliasDark": "core_cyan_50",   "hexLight": "#06B6D4", "hexDark": "#06B6D4" },
