{
  "tokenCategory": "Color",
  "description": "Color tokens for the design system. Source of truth: @color.pdf. Covers Background/Surface, Text, Brand/Link/Focus, Border/Divider, SemanticStates, DataVisualization.",
  "sourceDocument": "@color.pdf",
  "modeMapping": {
    "light": "Default mode",
    "dark": "Dark mode override"
  },
  "tokenGroups": {
    "backgroundSurface": {
      "description": "Page and container backgrounds",
