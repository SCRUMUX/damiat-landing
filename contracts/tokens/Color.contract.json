        "color_danger_surface":  { "aliasLight": "core_red_5",     "aliasDark": "core_red_99",    "hexLight": "#FEE5E5", "hexDark": "#2A1314" },
        "color_danger_text":     { "aliasLight": "core_white",     "aliasDark": "core_gray_10",   "hexLight": "#FFFFFF", "hexDark": "#E6EEF8" },
        "color_info_base":       { "aliasLight": "core_cyan_50",   "aliasDark": "core_cyan_50",   "hexLight": "#06B6D4", "hexDark": "#06B6D4" },
        "color_info_surface":    { "aliasLight": "core_cyan_5",    "aliasDark": "core_gray_90",   "hexLight": "#D9F5F5", "hexDark": "#07252B" },
        "color_info_text":       { "aliasLight": "core_white",     "aliasDark": "core_gray_10",   "hexLight": "#FFFFFF", "hexDark": "#E6EEF8" }
      }
