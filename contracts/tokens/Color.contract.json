        "color_link_default":  { "aliasLight": "core_blue_50",   "aliasDark": "core_blue_50",   "hexLight": "#5B9CFF", "hexDark": "#5B9CFF" },
        "color_link_hover":    { "aliasLight": "core_blue_60",   "aliasDark": "core_blue_60",   "hexLight": "#4A8AE6", "hexDark": "#4A8AE6" },
        "color_focus_outline": { "aliasLight": "core_blue_50",   "aliasDark": "core_blue_50",   "hexLight": "#5B9CFF", "hexDark": "#5B9CFF" },
        "color_active":        { "aliasLight": "core_violet_50", "aliasDark": "core_violet_50", "hexLight": "#6B5BFF", "hexDark": "#6B5BFF" }
