        "color_success_surface": { "aliasLight": "core_green_5",   "aliasDark": "core_green_99",  "hexLight": "#D9F5E5", "hexDark": "#11261B" },
        "color_success_text":    { "aliasLight": "core_white",     "aliasDark": "core_gray_10",   "hexLight": "#FFFFFF", "hexDark": "#E6EEF8" },
        "color_warning_base":    { "aliasLight": "core_yellow_50", "aliasDark": "core_yellow_50", "hexLight": "#FFB020", "hexDark": "#FFB020" },
        "color_warning_surface": { "aliasLight": "core_yellow_5",  "aliasDark": "core_yellow_99", "hexLight": "#FAECD1", "hexDark": "#2A210E" },
        "color_warning_text":    { "aliasLight": "core_gray_95",   "aliasDark": "core_gray_10",   "hexLight": "#353535", "hexDark": "#E6EEF8" },
