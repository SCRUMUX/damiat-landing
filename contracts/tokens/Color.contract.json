        "color_viz_categorical_5": { "aliasLight": "core_green_50",  "aliasDark": "core_green_50",  "hexLight": "#1DB954", "hexDark": "#1DB954" },
        "color_viz_categorical_6": { "aliasLight": "core_violet_50", "aliasDark": "core_violet_50", "hexLight": "#8B5CF6", "hexDark": "#8B5CF6" },
        "color_viz_categorical_7": { "aliasLight": "core_teal_10",   "aliasDark": "core_teal_10",   "hexLight": "#14B8A6", "hexDark": "#14B8A6" },
        "color_viz_categorical_8": { "aliasLight": "core_rose_60",   "aliasDark": "core_rose_60",   "hexLight": "#E11D48", "hexDark": "#E11D48" }
      }
    },
    "scrim": {
      "description": "Overlay / scrim colors for modals and dialogs",
      "tokens": {
        "color_scrim_light":  { "hexLight": "rgba(0,0,0,0.3)",  "hexDark": "rgba(0,0,0,0.45)" },
        "color_scrim_strong": { "hexLight": "rgba(0,0,0,0.45)", "hexDark": "rgba(0,0,0,0.6)" }
      }
    }
  },
  "usageRules": {
    "interactiveStates": {
      "description": "For interactive elements, use the following token pairs only",
      "primaryButton":   { "default": "color_brand_primary", "hover": "color_brand_hover", "pressed": "color_brand_pressed", "disabled": "color_bg_disabled" },
      "secondaryButton": { "default": "color_surface_2",     "hover": "color_surface_3",   "pressed": "color_surface_3",     "disabled": "color_bg_disabled" },
      "dangerButton":    { "default": "color_danger_base",   "hover": "color_danger_base",  "pressed": "color_danger_base",   "disabled": "color_bg_disabled" },
      "link":            { "default": "color_link_default",  "hover": "color_link_hover" }
    },
    "focus": {
      "description": "Focus rings must use effect tokens that reference color_focus_outline or color_danger_base"
    }
  },
  "constraints": {
    "noHardcodedColors": "All colors must come from this contract. Do not invent new color values.",
    "semanticOnly": "Use semantic token names (e.g. color_brand_primary), not primitive aliases (e.g. core_blue_50)."
  }
}
