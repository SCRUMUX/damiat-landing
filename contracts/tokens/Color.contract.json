        "color_text_muted":    { "aliasLight": "core_gray_60", "aliasDark": "core_gray_50", "hexLight": "#6B7280", "hexDark": "#9AA6B2" },
        "color_text_disabled": { "aliasLight": "core_gray_40", "aliasDark": "core_gray_50", "hexLight": "#9CA3AF", "hexDark": "#6B7280" },
        "color_text_on_brand": { "aliasLight": "core_white",   "aliasDark": "core_white",   "hexLight": "#FFFFFF", "hexDark": "#FFFFFF" }
      }
    },
    "brandLinkFocus": {
      "description": "Brand colors, interactive states, links, focus indicators",
      "tokens": {
        "color_brand_primary": { "aliasLight": "core_blue_50",   "aliasDark": "core_blue_50",   "hexLight": "#5B9CFF", "hexDark": "#5B9CFF" },
        "color_brand_hover":   { "aliasLight": "core_blue_60",   "aliasDark": "core_blue_60",   "hexLight": "#4A8AE6", "hexDark": "#4A8AE6" },
        "color_brand_pressed": { "aliasLight": "core_blue_70",   "aliasDark": "core_blue_70",   "hexLight": "#3578D4", "hexDark": "#3578D4" },
