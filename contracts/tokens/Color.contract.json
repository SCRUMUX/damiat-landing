        "color_bg_muted":    { "aliasLight": "core_gray_5",   "aliasDark": "core_gray_87",  "hexLight": "#E2EBFF", "hexDark": "#1B2B47" },
        "color_surface_1":   { "aliasLight": "core_white",    "aliasDark": "core_gray_80",  "hexLight": "#FFFFFF", "hexDark": "#1A2330" },
        "color_surface_2":   { "aliasLight": "core_gray_5",   "aliasDark": "core_gray_75",  "hexLight": "#F7F8FA", "hexDark": "#243041" },
        "color_surface_3":   { "aliasLight": "core_gray_20",  "aliasDark": "core_gray_70",  "hexLight": "#EDF2F8", "hexDark": "#2A3547" },
        "color_bg_disabled": { "aliasLight": "core_gray_10",  "aliasDark": "core_gray_85",  "hexLight": "#F3F4F6", "hexDark": "#1B2B47" }
      }
    },
    "text": {
