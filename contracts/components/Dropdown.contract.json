        "state": "open"
      },
      "style": {
        "borderColor": "color_brand_primary",
        "borderSide": "all",
        "popoverBorder": "color_brand_primary"
      },
      "tailwindClasses": [
        "[--popover-border:var(--color-brand-primary)]",
        "border",
        "border-[var(--color-brand-primary)]"
      ]
    },
