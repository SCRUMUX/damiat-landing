{
  "name": "@UI/RadioButton",
  "description": "RadioButton: круг с точкой внутри. 4 размера (xs, sm, md, lg). Состояния: base, filled, focus, always-filled, disabled.",
  "variantProps": [
    "size",
    "state"
  ],
  "variantAxes": {
    "size": [
      "xs",
      "sm",
      "md",
      "lg"
    ],
    "state": [
      "base",
      "filled",
      "focus",
      "always-filled",
      "disabled"
    ]
  },
  "variantRules": [
    {
      "when": {
        "state": "base"
      },
      "style": {
        "bg": "color_surface_3",
        "borderColor": "color_border_strong",
        "borderRadius": "radius_pill",
        "iconColor": "color_icon_on_brand",
        "opacity": 1
      },
      "tailwindClasses": [
        "[--icon-color:var(--color-icon-on-brand)]",
        "bg-[var(--color-surface-3)]",
        "border",
        "border-[var(--color-border-strong)]",
        "rounded-pill"
      ]
    },
    {
      "when": {
        "state": "filled"
      },
      "style": {
        "bg": "color_brand_primary",
        "borderColor": "color_brand_primary",
        "borderRadius": "radius_pill",
        "inner": "dot",
        "iconColor": "color_icon_on_brand"
      },
      "tailwindClasses": [
        "[--icon-color:var(--color-icon-on-brand)]",
        "bg-[var(--color-brand-primary)]",
        "border",
        "border-[var(--color-brand-primary)]",
        "rounded-pill",
        "[data-inner=\"dot\"]"
      ]
    },
    {
      "when": {
        "state": "always-filled"
      },
      "style": {
        "bg": "color_brand_primary",
        "borderColor": "color_brand_primary",
        "borderRadius": "radius_pill",
        "inner": "dot",
        "iconColor": "color_icon_on_brand",
        "opacityToken": "opacity_disabled"
      },
      "tailwindClasses": [
        "[--icon-color:var(--color-icon-on-brand)]",
        "bg-[var(--color-brand-primary)]",
        "border",
        "border-[var(--color-brand-primary)]",
        "rounded-pill",
        "opacity-[var(--opacity-disabled)]",
        "[data-inner=\"dot\"]"
      ]
    },
    {
      "when": {
        "state": "disabled"
      },
      "style": {
        "bg": "color_surface_3",
        "borderColor": "color_border_strong",
        "borderRadius": "radius_pill",
        "opacityToken": "opacity_disabled"
      },
      "tailwindClasses": [
        "bg-[var(--color-surface-3)]",
        "border",
        "border-[var(--color-border-strong)]",
        "rounded-pill",
        "opacity-[var(--opacity-disabled)]"
      ]
    },
    {
      "when": {
        "size": "xs"
      },
      "style": {
        "boxSize": "space_12",
        "innerSize": "space_6"
      },
      "tailwindClasses": [
        "w-[var(--space-12)]",
        "h-[var(--space-12)]",
        "[--inner-size:var(--space-6)]"
      ]
    },
    {
      "when": {
        "size": "sm"
      },
      "style": {
        "boxSize": "space_16",
        "innerSize": "space_6"
      },
      "tailwindClasses": [
        "w-[var(--space-16)]",
        "h-[var(--space-16)]",
        "[--inner-size:var(--space-6)]"
      ]
    },
    {
      "when": {
        "size": "md"
      },
      "style": {
        "boxSize": "space_20",
        "innerSize": "space_8"
      },
      "tailwindClasses": [
        "w-[var(--space-20)]",
        "h-[var(--space-20)]",
        "[--inner-size:var(--space-8)]"
      ]
    },
    {
      "when": {
        "size": "lg"
      },
      "style": {
        "boxSize": "space_24",
        "innerSize": "space_10"
      },
      "tailwindClasses": [
        "w-[var(--space-24)]",
        "h-[var(--space-24)]",
        "[--inner-size:var(--space-10)]"
      ]
    },
    {
      "when": {
        "state": "focus"
      },
      "style": {
        "bg": "color_surface_3",
        "borderColor": "color_brand_primary",
        "borderRadius": "radius_pill",
        "iconColor": "color_icon_on_brand",
        "focusRing": "effect_focus_brand"
      },
      "tailwindClasses": [
        "[--icon-color:var(--color-icon-on-brand)]",
        "bg-[var(--color-surface-3)]",
        "border",
        "border-transparent",
        "rounded-pill",
        "shadow-focus-brand"
      ]
    }
  ],
  "stateMachine": {
    "initial": "base",
    "stateAxis": "state",
    "states": [
      "base",
      "filled",
      "focus",
      "always-filled",
      "disabled"
    ],
    "transitions": [
      {
        "from": "base",
        "to": "hover",
        "trigger": "mouseenter"
      },
      {
        "from": "hover",
        "to": "base",
        "trigger": "mouseleave"
      },
      {
        "from": "base",
        "to": "focus",
        "trigger": "focus"
      },
      {
        "from": "focus",
        "to": "base",
        "trigger": "blur"
      }
    ]
  },
  "focusRing": "focus-visible:outline-none focus-visible:shadow-focus-brand focus-visible:border-transparent",
  "focusRingDanger": "focus-visible:outline-none focus-visible:shadow-focus-danger focus-visible:border-transparent",
  "responsiveProps": {
    "boxSize": {
      "xs": "space_12",
      "sm": "space_16",
      "md": "space_20",
      "lg": "space_24"
    }
  },
  "element": "button",
  "rootLayout": "none",
  "customStructure": "radioButton",
  "styleKeys": [
    "boxSize",
    "innerSize",
    "inner",
    "bg",
    "borderColor",
    "borderRadius",
    "iconColor",
    "opacityToken"
  ],
  "heightConstraint": "hug",
  "borderWidthToken": "border_width_base",
  "generatorStrategy": "template",
  "template": "RadioButton"
}