{
  "name": "@UI/Button",
  "description": "Semantic button. Варианты: тип (brand, base, ghost, outline + success, warning, danger), размер (sm, md, lg), состояние (base, active, hover, focus, disabled). Отступы и скругления — из токенов (space_button_*, radius_button). Light/dark через переменные. Иконки и текст — опциональные свойства (instance swap + booleans).",
  "variantProps": [
    "appearance",
    "size",
    "state"
  ],
  "variantAxes": {
    "appearance": [
      "brand",
      "base",
      "ghost",
      "ghost-danger",
      "ghost-warning",
      "ghost-success",
      "outline",
      "success",
      "warning",
      "danger"
    ],
    "size": [
      "sm",
      "md",
      "lg"
    ],
    "state": [
      "base",
      "active",
      "hover",
      "focus",
      "disabled"
    ]
  },
  "variantRules": [
    {
      "when": {
        "appearance": "brand",
        "state": "base"
      },
      "style": {
        "background": "color_brand_primary",
        "textColor": "color_text_on_brand",
        "borderColor": "color_brand_primary",
        "iconColor": "color_icon_on_brand"
      },
      "tailwindClasses": [
        "bg-[var(--color-brand-primary)]",
        "text-[var(--color-text-on-brand)]",
        "[--icon-color:var(--color-icon-on-brand)]",
        "border",
        "border-[var(--color-brand-primary)]"
      ]
    },
    {
      "when": {
        "appearance": "brand",
        "state": "hover"
      },
      "style": {
        "background": "color_brand_hover",
        "textColor": "color_text_on_brand",
        "borderColor": "color_brand_hover",
        "iconColor": "color_icon_on_brand"
      },
      "tailwindClasses": [
        "bg-[var(--color-brand-hover)]",
        "text-[var(--color-text-on-brand)]",
        "[--icon-color:var(--color-icon-on-brand)]",
        "border",
        "border-[var(--color-brand-hover)]"
      ]
    },
    {
      "when": {
        "appearance": "brand",
        "state": "active"
      },
      "style": {
        "background": "color_brand_pressed",
        "textColor": "color_text_on_brand",
        "borderColor": "color_brand_pressed",
        "iconColor": "color_icon_on_brand"
      },
      "tailwindClasses": [
        "bg-[var(--color-brand-pressed)]",
        "text-[var(--color-text-on-brand)]",
        "[--icon-color:var(--color-icon-on-brand)]",
        "border",
        "border-[var(--color-brand-pressed)]"
      ]
    },
    {
      "when": {
        "appearance": "brand",
        "state": "disabled"
      },
      "style": {
        "background": "color_brand_primary",
        "textColor": "color_text_on_brand",
        "borderColor": "color_brand_primary",
        "iconColor": "color_icon_on_brand",
        "opacityToken": "opacity_disabled"
      },
      "tailwindClasses": [
        "bg-[var(--color-brand-primary)]",
        "text-[var(--color-text-on-brand)]",
        "[--icon-color:var(--color-icon-on-brand)]",
        "border",
