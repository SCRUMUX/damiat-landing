# Synaptik AI Icon Builder — keep real keys here (gitignored). Other repos: synaptik.local.env + npm run synaptik:ui
FAL_KEY=
# Optional: fal CDN download (default 120s timeout, 4 retries)
# SYNAPTIK_FAL_DOWNLOAD_TIMEOUT_MS=120000
# SYNAPTIK_FAL_DOWNLOAD_RETRIES=4
# SYNAPTIK_FAL_SYNC_MODE=1  (default on; PNG in API response, no CDN fetch — set 0 to use URL download)
OPENAI_API_KEY=
# OpenRouter (recommended for cost): OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=
# Cheap vision: google/gemini-2.0-flash-001 or openai/gpt-4o-mini — avoid gpt-4o for analyze
SYNAPTIK_VISION_MODEL=google/gemini-2.0-flash-001
SYNAPTIK_VISION_PROVIDER=openai
# Single vision call for Style DNA + content structure (saves ~1 API round-trip)
SYNAPTIK_COMBINED_ANALYZE=0
ANTHROPIC_API_KEY=
SYNAPTIK_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENROUTER_HTTP_REFERER=https://github.com/SCRUMUX/AICADS-PRO
OPENROUTER_APP_TITLE=Synaptik Icon Builder
