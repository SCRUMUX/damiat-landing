{
  "$schema": "DAMIAT color tokens — maps to ai-ds-spec.json",
  "meta": {
    "name": "DAMIAT",
    "style": "Agro Capital Intelligence UI",
    "source": "etc/DAMIAT-Color-System.pdf"
  },
  "concept": {
    "harvest": "financial asset",
    "storage": "capital management",
    "interface": "decision system",
    "tone": ["financial", "controlled", "calm", "premium industrial", "capital-oriented"]
  },
  "color": {
    "bgPrimary": "#F7F8F5",
    "bgSecondary": "#EEF2EC",
    "surface": "#FFFFFF",
    "surfaceMuted": "#F1F4F0",
    "textPrimary": "#0E1512",
    "textSecondary": "#2C3A34",
    "textMuted": "#6B7C73",
    "green900": "#0B3D2E",
    "green800": "#0F4D3A",
    "green700": "#146B4F",
    "greenPrimary": "#22A06B",
    "greenAccent": "#2BCB7A",
    "greenSoft": "#A7E6C4",
    "data900": "#0C1F18",
    "data800": "#102820",
    "data700": "#143329",
    "success": "#22A06B",
    "warning": "#E6A23C",
    "danger": "#E25555",
    "border": "#D9E2DA",
    "divider": "#E6EEE8",
    "hover": "rgba(20, 107, 79, 0.06)",
    "overlayLight": "rgba(255, 255, 255, 0.6)",
    "overlayDark": "rgba(0, 0, 0, 0.25)",
    "shadowBase": "#0E1512"
  },
  "rules": {
    "greenHierarchy": {
      "coreGreen": "structure / serious blocks / dashboards",
      "growthGreen": "profit / dynamics / DAMIAT Index / success",
      "softGreen": "background highlights"
    },
    "neverUse": ["neon cyan", "blue SaaS palette", "#00FF00", "eco green branding"]
  },
  "typography": {
    "fontFamily": { "primary": "Inter", "alt": "Manrope" },
    "scale": {
      "h1": { "fontSize": 48, "lineHeight": 56, "fontWeight": 600 },
      "h2": { "fontSize": 36, "lineHeight": 44, "fontWeight": 600 },
      "h3": { "fontSize": 28, "lineHeight": 36, "fontWeight": 600 },
      "body": { "fontSize": 16, "lineHeight": 24, "fontWeight": 400 },
      "small": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400 }
    },
    "tabularNums": true
  },
  "spacing": [4, 8, 12, 16, 24, 32, 48, 64],
  "radius": { "sm": 12, "md": 20, "lg": 28, "xl": 36 },
  "shadow": {
    "sm": "0 2px 10px rgba(14, 21, 18, 0.06)",
    "md": "0 10px 30px rgba(14, 21, 18, 0.10)",
    "lg": "0 20px 60px rgba(14, 21, 18, 0.14)"
  },
  "glass": { "backdropBlur": 12, "background": "rgba(255, 255, 255, 0.6)" },
  "motion": { "durationMinMs": 200, "durationMaxMs": 600, "easing": "ease-out" }
}
