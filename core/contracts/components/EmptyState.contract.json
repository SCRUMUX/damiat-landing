  "defaultContent": "No data found. Try adjusting your filters or adding new items.",
  "element": "div",
  "rootLayout": "dynamic",
  "rootSizing": {
    "main": "hug",
    "cross": "hug"
  },
  "rootAlign": {
    "main": "center",
    "cross": "center"
  },
  "slots": [
    {
      "name": "icon",
      "figmaName": "Icon",
      "type": "icon",
      "optional": true,
      "defaultVisible": true,
      "sizing": "fixed"
    },
    {
      "name": "textBlock",
      "figmaName": "Text",
      "type": "frame",
      "optional": false,
      "sizing": "fill",
      "layout": "vertical",
      "children": [
        {
          "name": "title",
          "figmaName": "Title",
          "type": "text",
          "optional": false,
          "default": "No items yet",
