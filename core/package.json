{
  "name": "@ai-ds/core",
  "version": "0.7.6",
  "description": "AI Design System — reusable architectural core (tokens, contracts, components, hooks, pattern blocks, Figma plugin). Powered by Radix UI / cmdk / vaul / sonner under the hood; consumers see only the AICADS semantic surface.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "manifest:build": "node scripts/build-manifest.mjs",
    "manifest:check": "node scripts/check-manifest-sync.mjs",
    "tokens:build": "node scripts/build-tokens.mjs",
    "tokens:check": "node scripts/check-tokens-sync.mjs",
    "patterns:check": "node scripts/check-patterns-sync.mjs",
    "patterns:build": "node scripts/build-patterns.mjs",
    "figma:embed-manifest": "node scripts/embed-figma-manifest.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --rulesdir eslint-rules",
    "api:build-dts": "tsc -p tsconfig.api.json",
    "api:extract": "npm run api:build-dts && api-extractor run --local",
    "api:check": "npm run api:build-dts && api-extractor run",
    "storybook": "npm run storybook --prefix playground",
    "storybook:consumer": "npm run storybook --prefix templates/consumer-storybook/fixture",
    "storybook:build": "npm run build-storybook --prefix playground"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./spec": "./ai-ds-spec.json",
    "./manifest": "./ai-manifest.json",
    "./patterns": "./ai-patterns.json",
    "./tokens": "./config/css-variables/tokens.css",
    "./tailwind": "./config/tailwind/tailwind.config.cjs",
    "./postcss": "./postcss.config.cjs",
    "./contracts/*": "./contracts/components/*.contract.json",
    "./components": "./components/index.ts",
    "./components/*": "./components/primitives/*/index.ts",
    "./icons": "./components/icons/index.tsx",
    "./hooks": "./hooks/index.ts",
    "./hooks/*": "./hooks/*.ts",
    "./shared": "./components/primitives/_shared/index.ts",
    "./layout": "./layout/index.ts",
    "./recipes": "./recipes/index.ts",
    "./blocks": "./blocks/index.ts",
    "./blocks/HeroBlock": "./blocks/marketing/HeroBlock/index.ts",
    "./blocks/FeaturesBlock": "./blocks/marketing/FeaturesBlock/index.ts",
    "./blocks/PricingBlock": "./blocks/marketing/PricingBlock/index.ts",
    "./blocks/CTABlock": "./blocks/marketing/CTABlock/index.ts",
    "./blocks/FooterBlock": "./blocks/marketing/FooterBlock/index.ts",
    "./blocks/NavbarBlock": "./blocks/marketing/NavbarBlock/index.ts",
    "./blocks/LogoCloudBlock": "./blocks/marketing/LogoCloudBlock/index.ts",
    "./blocks/StatsBlock": "./blocks/marketing/StatsBlock/index.ts",
    "./blocks/TestimonialsBlock": "./blocks/marketing/TestimonialsBlock/index.ts",
    "./blocks/FAQBlock": "./blocks/marketing/FAQBlock/index.ts",
    "./blocks/HowItWorksBlock": "./blocks/marketing/HowItWorksBlock/index.ts",
    "./blocks/NewsletterBlock": "./blocks/marketing/NewsletterBlock/index.ts",
    "./blocks/EventsBlock": "./blocks/marketing/EventsBlock/index.ts",
    "./blocks/ServicesBlock": "./blocks/marketing/ServicesBlock/index.ts",
    "./blocks/SolutionsBlock": "./blocks/marketing/SolutionsBlock/index.ts",
    "./blocks/TrustBlock": "./blocks/marketing/TrustBlock/index.ts",
    "./blocks/SupportBlock": "./blocks/marketing/SupportBlock/index.ts",
    "./blocks/ShowcasePanelBlock": "./blocks/marketing/ShowcasePanelBlock/index.ts",
    "./blocks/BlogBlock": "./blocks/marketing/BlogBlock/index.ts",
    "./blocks/PartnersBlock": "./blocks/marketing/PartnersBlock/index.ts",
    "./blocks/ContactHeroBlock": "./blocks/marketing/ContactHeroBlock/index.ts",
    "./blocks/WhyUsBlock": "./blocks/marketing/WhyUsBlock/index.ts",
    "./blocks/ChooseUsBlock": "./blocks/marketing/ChooseUsBlock/index.ts",
    "./blocks/ProcessBlock": "./blocks/marketing/ProcessBlock/index.ts",
    "./blocks/LandingPageTemplate": "./blocks/marketing/LandingPageTemplate/index.ts",
    "./blocks/DamiatCalculatorBlock": "./blocks/marketing/DamiatCalculatorBlock/index.ts",
    "./blocks/DamiatLandingPage": "./blocks/marketing/DamiatLandingPage/index.ts",
    "./behaviors": "./behaviors/index.ts",
    "./utils": "./utils/token-resolver.ts",
    "./images/*": "./images/*",
    "./eslint-config": "./aicads.eslintrc.shared.cjs",
    "./storybook": "./storybook/index.ts",
    "./storybook/createMainConfig": "./storybook/createMainConfig.mjs",
    "./storybook/createMainConfig.mjs": "./storybook/createMainConfig.mjs",
    "./storybook/createPreview": "./storybook/createPreview.tsx",
    "./storybook/engine-styles": "./storybook/engine-styles.ts",
    "./storybook/marketingViewports": "./storybook/marketingViewports.ts",
    "./storybook/tailwind": "./storybook/tailwind.config.cjs",
    "./storybook/postcss": "./storybook/postcss.config.cjs",
    "./storybook/index.css": "./storybook/index.css"
  },
  "files": [
    "components",
    "config",
    "contracts",
    "hooks",
    "layout",
    "blocks",
    "recipes",
    "schemas",
    "behaviors",
    "utils",
    "images",
    "storybook",
    "templates",
    "scripts",
    "ai-ds-spec.json",
    "ai-manifest.json",
    "ai-patterns.json",
    "aicads.eslintrc.shared.cjs",
    "postcss.config.cjs",
    "src",
    "etc",
    "docs",
    "eslint-rules"
  ],
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.47.0",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "ai-ds",
    "figma",
    "tailwind",
    "contracts"
  ],
  "license": "MIT"
}
