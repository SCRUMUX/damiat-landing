{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "outDir": "./.api-temp",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmitOnError": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom", "node"],
    "baseUrl": ".",
    "paths": {
      "react": ["node_modules/@types/react"]
    }
  },
  "include": ["types/**/*.d.ts", "src/**/*.ts", "src/**/*.tsx", "components/**/*.ts", "components/**/*.tsx", "hooks/**/*.ts", "layout/**/*.ts", "behaviors/**/*.ts", "utils/**/*.ts", "blocks/**/*.ts", "blocks/**/*.tsx", "recipes/**/*.ts", "generated-icons/**/*.ts"],
  "exclude": ["**/*.stories.tsx", "node_modules", "dist", "playground", "figma-plugin"]
}
